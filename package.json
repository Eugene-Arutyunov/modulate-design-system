{
  "name": "@eugene-arutyunov/modulate-design-system",
  "version": "0.0.2",
  "description": "CSS design tokens for Modulate",
  "license": "MIT",
  "main": "dist/tokens.css",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": "./dist/tokens.css",
    "./palette": "./dist/palette.css",
    "./colors": "./dist/colors.css",
    "./typography": "./dist/typography.css",
    "./spacers": "./dist/spacers.css",
    "./layout": "./dist/layout.css",
    "./padding": "./dist/padding.css",
    "./animations": "./dist/animations.css",
    "./shadcn": "./dist/shadcn.css"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "icons:build": "node scripts/generate-svg-sprite.js",
    "prebuild": "node scripts/generate-svg-sprite.js && rm -rf _site",
    "build": "eleventy",
    "build:clean": "node scripts/generate-svg-sprite.js && eleventy",
    "export:prosocial:single": "node scripts/export-prosocial-single-html.js",
    "predev": "node scripts/generate-svg-sprite.js",
    "dev": "eleventy --serve",
    "tokens:build": "node scripts/build-tokens.js",
    "prepare": "npm run tokens:build"
  },
  "dependencies": {
    "browserslist": "^4.24.0",
    "lightningcss": "^1.29.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0"
  }
}
